# ─── Qwen via Alibaba Cloud Model Studio (OpenAI-compatible API) ───
# Get a key: https://modelstudio.console.alibabacloud.com  (International / Singapore account)
DASHSCOPE_API_KEY=your-model-studio-api-key

# International (Singapore ap-southeast-1) compatible-mode endpoint.
# Mainland China accounts use: https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Confidence-cascade tiers (qwen-turbo is deprecated -> use qwen-flash).
QWEN_MODEL_FLASH=qwen-flash
QWEN_MODEL_MAX=qwen-max

# ─── MongoDB Atlas (M0 free tier) — used from Day 2 onward ───
MONGODB_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=quorum

# ─── Web ───
WEB_ORIGIN=http://localhost:3000
